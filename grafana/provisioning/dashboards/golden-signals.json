{
  "title": "Golden Signals - Order Service",
  "uid": "golden-signals-v2",
  "tags": ["golden-signals", "order-service", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Latência (P50, P95, P99)",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "description": "Tempo de resposta das requisições — quanto menor, melhor",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50 (mediana)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        },
        {
          "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])",
          "legendFormat": "Média",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {
        "legend": {"calcs": ["mean", "max", "last"], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 2,
      "title": "Tráfego (requisições por segundo)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "description": "Volume de requisições por segundo",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "Total req/s",
          "refId": "A"
        },
        {
          "expr": "rate(http_requests_total{status='success'}[1m])",
          "legendFormat": "Sucesso",
          "refId": "B"
        },
        {
          "expr": "rate(http_requests_total{status='error'}[1m])",
          "legendFormat": "Erro",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "decimals": 1}
      }
    },
    {
      "id": 3,
      "title": "Taxa de erro (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "description": "Percentual de requisições com erro",
      "targets": [
        {
          "expr": "rate(http_requests_total{status='error'}[1m]) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "Taxa de erro",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {
        "legend": {"calcs": ["last", "mean", "max"], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      }
    },
    {
      "id": 4,
      "title": "Saturação — CPU",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 18},
      "description": "Uso de CPU do processo",
      "targets": [
        {
          "expr": "rate(process_cpu_usage[1m]) * 100",
          "legendFormat": "CPU processo (%)",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage * 100",
          "legendFormat": "CPU sistema (%)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Saturação — memória (JVM heap)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "description": "Uso de memória heap da JVM",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area='heap'}",
          "legendFormat": "Heap usado",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area='heap'}",
          "legendFormat": "Heap máximo",
          "refId": "B"
        },
        {
          "expr": "(jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'}) * 100",
          "legendFormat": "Uso (%)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "bytes", "decimals": 0},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Uso (%)"},
            "properties": [{"id": "unit", "value": "percent"}]
          }
        ]
      }
    },
    {
      "id": 6,
      "title": "Saturação — conexões e threads",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 26},
      "description": "Conexões ativas no banco e requisições simultâneas",
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "Conexões DB ativas",
          "refId": "A"
        },
        {
          "expr": "http_requests_active",
          "legendFormat": "Requisições ativas",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "Threads ativas",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "decimals": 0}
      }
    },
    {
      "id": 7,
      "title": "Resumo — golden signals",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 26},
      "description": "Status atual do sistema",
      "targets": [
        {
          "expr": "rate(http_requests_total{status='error'}[1m]) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "Taxa de erro (%)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "Tráfego (req/s)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "Latência P95 (s)",
          "refId": "C"
        },
        {
          "expr": "rate(process_cpu_usage[1m]) * 100",
          "legendFormat": "CPU (%)",
          "refId": "D"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["last"]},
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    }
  ],
  "time": {"from": "now-5m", "to": "now"}
}